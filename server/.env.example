# WebSocket server (Browser ↔ Backend)
WS_PORT=3001
WS_HOST=localhost

# TCP client (Backend ↔ Target Server)
TCP_HOST=192.168.1.100
TCP_PORT=5000
TCP_RECONNECT_DELAY=1000
TCP_MAX_RECONNECT_DELAY=30000
TCP_MAX_RECONNECT_ATTEMPTS=10
TCP_CONNECTION_TIMEOUT=5000

# gRPC / ts_auralization_controller (Backend → SAPF)
GRPC_ENDPOINT=127.0.0.1:50051
GRPC_INSTANCE_ID=
GRPC_FRAME_INTERVAL_MS=20
# Path to ts_auralization_controller compiled entry point (dist/main.js)
# Leave blank to use default relative path (sapf/examples/ts_auralization_controller/dist/main.js)
# TS_CONTROLLER_PATH=D:/Project_Plus/Harmman--VirtualListenning/sapf/examples/ts_auralization_controller/dist/main.js
# Number of replay frames per "Send to Network" session (default 300 = 6 s @ 20 ms)
TS_CONTROLLER_FRAMES=300
